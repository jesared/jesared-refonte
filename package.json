{
  "name": "jesared-refonte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const p=require('path');const root=p.dirname(process.env.npm_package_json||p.join(process.cwd(),'package.json'));const file=p.join(root,'scripts','npm-next-bootstrap.cjs');process.argv=['node',file,'dev'];require(file);\"",
    "build": "node -e \"const p=require('path');const root=p.dirname(process.env.npm_package_json||p.join(process.cwd(),'package.json'));const file=p.join(root,'scripts','npm-next-bootstrap.cjs');process.argv=['node',file,'build'];require(file);\"",
    "start": "node -e \"const p=require('path');const root=p.dirname(process.env.npm_package_json||p.join(process.cwd(),'package.json'));const file=p.join(root,'scripts','npm-next-bootstrap.cjs');process.argv=['node',file,'start'];require(file);\"",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
